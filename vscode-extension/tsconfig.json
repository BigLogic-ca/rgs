{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "outDir": "./build",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    // "moduleResolution": "node",
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules/@types/vscode"
    ]
  },
  "include": [
    "extension.ts",
    "json/**/*.json"
  ],
  "exclude": [
    "node_modules",
    "build"
  ]
}
